    <div class="container">
        <!-- قسم تسجيل الدخول / التحقق -->
        <div class="card">
            <div class="card-header">إنشاء حساب / تسجيل دخول</div>
            <div class="card-content">
                <input type="email" id="userEmail" placeholder="أدخل البريد الإلكتروني (Gmail)">
                <button class="btn-verify" onclick="sendCode()">إرسال كود التحقق</button>
                
                <div id="verifySection" style="display:none; margin-top:15px;">
                    <input type="text" id="verifyCode" placeholder="أدخل الكود المكون من 6 أرقام">
                    <button class="btn-verify" style="background:#47cf73;" onclick="checkCode()">تأكيد الكود</button>
                </div>
            </div>
        </div>

        <!-- منشور تجريبي -->
        <div class="card">
            <div class="card-header">@Error_404</div>
            <div class="card-img"><img src="https://via.placeholder.com/600" alt="Post" style="width:100%"></div>
            <div class="card-content">
                <div class="likes">100 إعجاب</div>
                <div><b>Error_404</b> أول منشور في موقعي الجديد LinkUp! 🔥</div>
            </div>
        </div>
    </div>

    <script>
        function sendCode() {
            const email = document.getElementById('userEmail').value;
            if(email.includes("@")) {
                alert("تم إرسال طلب الكود إلى السيرفر الخاص بك!");
                document.getElementById('verifySection').style.display = 'block';
            } else {
                alert("يرجى إدخال إيميل صحيح");
            }
        }

        function checkCode() {
            const code = document.getElementById('verifyCode').value;
            if(code.length === 6) {
                alert("تم التحقق بنجاح! أهلاً بك في LinkUp");
            } else {
                alert("الكود خاطئ، حاول مرة أخرى");
            }
        }
    </script>

